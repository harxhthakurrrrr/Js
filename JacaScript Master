# Spread / Rest:-

Spread  = भेजना (Send) - Values ko bhej rahe ho

Rest    = प्राप्त करना (Receive) - Values ko receive kar rahe ho

Simple Examples se samajh:

📤 Spread - Bhejna (Send)

javascript



let gifts = \\\["watch", "phone", "laptop"];



// Gift ko bhej do function ko (spread se)

function receiveGifts(item1, item2, item3) {

\&#x20;   console.log("Mila:", item1, item2, item3);

}



receiveGifts(...gifts);  // 📦 Bhej diya

// Output: Mila: watch phone laptop



📥 Rest - Lena (Receive)

javascript



// Saare gifts receive kar lo (rest se)

function packGifts(...saareGifts) {  // 📨 Receive kiye

\&#x20;   console.log("Package mein hai:", saareGifts);

}



packGifts("watch", "phone", "laptop", "tablet");

// Output: Package mein hai: \\\["watch", "phone", "laptop", "tablet"]



