Typeof :-
typeof ek operator hai jo batata hai ki
variable ka data type kya hai.



// Primitives
let age = 22;                  // number
let name = "Harsh";            // string
let isStudent = true;          // boolean
let job;                       // undefined
let empty = null;              // null

console.log(typeof age);       // "number"
console.log(typeof name);      // "string"
console.log(typeof isStudent); // "boolean"
console.log(typeof job);       // "undefined"
console.log(typeof empty);     // "object" ← famous bug!

// Type matters in operations
console.log(5 + 3);            // 8
console.log("5" + 3);          // "53" ← string join
console.log("5" - 3);          // 2   ← string number mein convert
console.log(10 + true);        // 11  (true = 1)

// Non-primitive
let person = { name: "Harsh", city: "UP" };
let hobbies = ["coding", "gaming"];
console.log(typeof person);    // "object"
console.log(typeof hobbies);   // "object"
console.log(typeof console.log); // "function"
